{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Lumorix DropDash",
    "version":  "2.0.0",
    "identifier":  "com.lumorix.dropdash.app",
    "build":  {
                  "beforeBuildCommand":  "",
                  "beforeDevCommand":  "",
                  "frontendDist":  "./ui"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Lumorix DropDash",
                                    "width":  1280,
                                    "height":  900,
                                    "resizable":  true,
                                    "fullscreen":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  false,
                   "targets":  "all"
               }
}