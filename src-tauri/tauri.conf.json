{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumorix Launcher",
  "version": "0.2.1",
  "identifier": "com.lumorix.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumorix Launcher",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ipc: https:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Game",
    "shortDescription": "Lumorix local-first game launcher",
    "longDescription": "Desktop game launcher with local-first installs, package integrity verification and signed release update flow.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "signCommand": {
        "cmd": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "scripts/sign-windows.ps1",
          "%1"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ju53648/launcher/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDQjBFNjgzMUIzM0QwRDUKUldUVjBETWJnK2F3WEY5MU9ZcExIVEgxaGJESGNYbmgxWXhiU2RVVVIxOVNVRFYwUFhFNjBGczAK"
    }
  }
}
